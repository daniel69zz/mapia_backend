# ============================================================
# Mapia Backend - Variables de entorno (EJEMPLO)
# Copiar a .env y completar. NUNCA commitear el .env real.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Orígenes permitidos para CORS, separados por coma (* solo para dev)
CORS_ORIGINS=*

# --- Base de datos: Supabase (PostgreSQL + PostGIS, free tier) ---
# La base de datos vive SIEMPRE en Supabase (dev y prod).
# Usa el "Session pooler" (Connect -> Session mode) de tu proyecto Supabase.
# El esquema se crea UNA vez ejecutando db/supabase-schema.sql en el SQL Editor;
# por eso DB_RUN_MIGRATIONS=false (no se corren migraciones contra Supabase).
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=5432
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=<tu-db-password>
DB_DATABASE=postgres
DB_SSL=true
DB_RUN_MIGRATIONS=false

# --- Alternativa solo si quieres PostgreSQL local (requiere PostGIS instalado) ---
# Descomenta esto y comenta el bloque Supabase de arriba. En local SÍ se usan
# migraciones TypeORM (npm run migration:run).
#DB_HOST=localhost
#DB_PORT=5432
#DB_USERNAME=mapia_user
#DB_PASSWORD=mapia_password
#DB_DATABASE=mapia_db
#DB_SSL=false
#DB_RUN_MIGRATIONS=true

# --- JWT (cambiar los secretos en cualquier entorno real) ---
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Storage de archivos ---
# local = disco (dev) | supabase = Supabase Storage | gcs = Google Cloud Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=uploads
# URL pública base para servir archivos locales en dev
STORAGE_PUBLIC_URL=http://localhost:3000/static
# Solo si STORAGE_DRIVER=supabase:
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=alert-images
# Solo si STORAGE_DRIVER=gcs:
GCS_BUCKET_NAME=mapia-media
GCP_PROJECT_ID=

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_GEOCODING_ENABLED=true
GOOGLE_MAPS_PLACES_ENABLED=true

# --- IA de visión (Vertex AI / Gemini) ---
# Si AI_VISION_ENABLED=false, POST /reports/analyze-photo responde 503.
AI_VISION_ENABLED=false
# true = Vertex AI (recomendado con crédito GCP) | false = Google AI Studio (API key)
GOOGLE_GENAI_USE_VERTEXAI=true
# ID del proyecto GCP donde corre y se factura Vertex (NO el nombre; ej. mapia-470213).
# Obtenlo con: gcloud config get-value project
GOOGLE_CLOUD_PROJECT=
# Región donde se ejecuta el modelo (latencia/disponibilidad). us-central1 = misma
# región del bucket Always Free y donde está gemini-2.0-flash.
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash
# Auth de Vertex = ADC (NO va en el .env):
#   local:     gcloud auth application-default login
#   Cloud Run: service account con rol roles/aiplatform.user
# Solo si GOOGLE_GENAI_USE_VERTEXAI=false (fallback a Google AI Studio):
GEMINI_API_KEY=
# Umbrales de las reglas de confianza (0..1)
AI_AUTO_PUBLISH_THRESHOLD=0.85
AI_REVIEW_THRESHOLD=0.6
# Transcripción de voz del chatbot (OpenAI Whisper). Sin esta key, POST /chatbot/transcribe responde 503.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1

# --- Geo / negocio ---
DEFAULT_RADIUS_KM=3
MAX_RADIUS_KM=50

# --- Rate limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=120
